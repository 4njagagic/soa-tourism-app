# Global docker-compose env

# --- Shared ---
JWT_SECRET=mySecretKeyForJWTTokenGenerationAndValidationPurposeOnlyForDevelopmentAndTestingEnvironment

# --- Stakeholders DB ---
STAKEHOLDERS_DB_USER=stakeholders_user
STAKEHOLDERS_DB_PASSWORD=stakeholders_pass
STAKEHOLDERS_DB_NAME=stakeholders_db
STAKEHOLDERS_DB_HOST_PORT=5432

# --- Blog DB ---
BLOG_DB_USER=blog_user
BLOG_DB_PASSWORD=blog_pass
BLOG_DB_NAME=blog_db
BLOG_DB_HOST_PORT=5433

# --- Service ports (host:container) ---
STAKEHOLDERS_SERVICE_PORT=8081
BLOG_SERVICE_PORT=8082
FRONTEND_HOST_PORT=3001
FRONTEND_CONTAINER_PORT=3000

# --- Frontend API base URLs (used at build time by Vite) ---
# Use same-origin paths so nginx/vite proxy can route internally.
VITE_API_URL=/api
VITE_BLOG_API_URL=/blog-api/api
